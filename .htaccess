<IfModule mod_rewrite.c>
    RewriteEngine On

    # Route everything through Laravel's public/ front controller.
    # Required on shared hosting where the document root is the project root
    # rather than the public/ directory.

    # Serve real files/directories directly (e.g. public/build/*, public/storage/*).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>
