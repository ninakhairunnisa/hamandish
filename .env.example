APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Shared-hosting sub-path config (set these in production only) ────────────
# When the app lives at a sub-path (e.g. https://menon.ir/hamandish/) set:
#
#   VITE_APP_BASE=/hamandish/        ← Vue-router base
#   VITE_BUILD_BASE=/hamandish/build/ ← Vite compiled-asset base
#
# Leave both unset (or /) for root-domain / artisan-serve deployments.
VITE_APP_BASE=/
VITE_BUILD_BASE=/build/

# IPPanel SMS Gateway
IPPANEL_API_KEY=
IPPANEL_PATTERN_CODE=
# نام متغیر داخل متن پترن. اگر متن پترن «کد ورود شما: %code%» باشد مقدار «code» است.
IPPANEL_PATTERN_VARIABLE=code
IPPANEL_SENDER=

# Bale messenger mini-app + bot
BALE_BOT_TOKEN=
BALE_BOT_USERNAME=
BALE_WEBHOOK_SECRET=

# Eitaa messenger mini-app + bot
EITAA_BOT_TOKEN=
EITAA_BOT_USERNAME=
EITAA_WEBHOOK_SECRET=
